  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "INTERNAL_API_KEY", "value": "your-secret" }
  ],
  "item": [
    {
      "name": "Natal chart",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{INTERNAL_API_KEY}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"date\": \"1987-05-15\",\n  \"time\": \"13:45:00\",\n  \"tz\": \"+03:00\",\n  \"lat\": 59.93,\n  \"lon\": 30.36\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/natal",
          "host": ["{{baseUrl}}"],
          "path": ["natal"]
        }
      }
    },
