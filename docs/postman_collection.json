{
  "info": {
    "name": "Astro Engine API Examples",
    "_postman_id": "astro-engine-examples",
    "description": "Примеры запросов к основным эндпойнтам сервиса",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
